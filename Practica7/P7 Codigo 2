volatile char estado=0;
char modo=0;

void ADC_Init(){ 
    ANSEL = 0X01; 
    ADCON0 = 0X81; 
    ADCON1 = 0X80; 
} 
unsigned int ADC_Read(){
    __delay_us(5); 
   GO_nDONE = 1; 
   while(GO_nDONE); 
   return((ADRESH<<8)+ ADRESL); 
} 
void main (void){ 
    ANSEL = 0;
    ANSELH = 0;
    OPTION_REG = OPTION_REG & 0b01111111;
    
    TRISD = 0;
    TRISC = 0;
    TRISB = 0xFF;
    
    GIE = 1;
    INTE = 1;
    INTEDG = 0;
    ADC_Init(); 
    LCD lcd = {&PORTC, 2, 3, 4, 5, 6, 7}; 
    LCD_Init(lcd); char buffer[10]; 
    
    while(1){ 
        LCD_Clear(); 
        LCD_Set_Cursor(0,0); 
        
            
        //No optimizado 
        //float volt = adc_result * 5.0/1023; 
        //sprintf(buffer, "%.1f", volt); 
        //LCD_putrs(buffer); unsigned int volt =(adc_result *50000)/1023; 
       
        unsigned int adc_result = ADC_Read(); 
        unsigned int volt = (adc_result *50000)/1023;
        unsigned int part_int = volt /10000; 
        unsigned int part_dec = volt % 10000; 
        
        if(estado){
            if(modo==1){
                LCD_putrs("Porcentaje: "); 
            }
            else{
                LCD_putrs("ACD: "); 
                sprintf(buffer,"%u", adc_result);

            }
        }
        else{
            LCD_putrs("Voltaje: "); 
            LCD_Set_Cursor(0,9);

        sprintf(buffer,"%u.%u", part_int, part_dec);
        LCD_putrs(buffer);
        __delay_ms(200); 
        }
    } 
}

void __interrupt() ISR(void){
    if(INTF){
        INTF = 0;
        GIE = 0;
        estado =!estado; //EJECUTAR INTERRUPCION
        modo++;
        GIE = 1; //REACTIVAR OTRASINTERRUPCIONES 
        if (modo==3){
            modo=0;
        }
    }
}
